# ==============================================================================
# STOCKORA ENTERPRISE CONFIGURATION TEMPLATE
# ==============================================================================

# --- Application Setup ---
PORT=5000
NODE_ENV=development

# --- Security & CORS Settings ---
CORS_ORIGIN=http://127.0.0.1:5173
COOKIE_SECRET=your_cookie_secure_passphrase_here
SECURE_COOKIES=false # Set to true in production with HTTPS

# --- Database Connections ---
MONGODB_URI=mongodb://127.0.0.1:27017/stockora
REDIS_URL=redis://127.0.0.1:6379

# --- Authentication & Session Keys ---
JWT_SECRET=your_jwt_signing_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_key_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- Winston Logging Level ---
LOG_LEVEL=info

# --- API Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100

# --- File Storage & Uploads (Multer / Cloudinary) ---
UPLOAD_MAX_SIZE=5242880 # 5MB in bytes
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# --- Email Notifications (BullMQ / Nodemailer) ---
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_USER=your_smtp_user_name_here
SMTP_PASS=your_smtp_password_here
EMAIL_FROM=noreply@stockora.com

# --- Future Payment Gateways (Stripe / PayPal) ---
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# --- Future AI Services (OpenAI / Gemini / DeepMind) ---
AI_SERVICE_API_KEY=your_ai_service_api_key_here
AI_MODEL_NAME=your_preferred_model_name_here
